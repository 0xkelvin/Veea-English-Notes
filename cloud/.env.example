# =============================================================================
# Application
# =============================================================================
APP_NAME=english-notes-cloud
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8080
APP_WORKERS=4
APP_REQUEST_TIMEOUT_SECS=30
APP_BODY_LIMIT_BYTES=1048576
RUST_LOG=info,english_notes_cloud=debug,sqlx=warn,tower_http=debug

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
DATABASE_URL=postgres://app_user:app_password@localhost:5432/english_notes
DATABASE_MAX_CONNECTIONS=20
DATABASE_MIN_CONNECTIONS=5
DATABASE_ACQUIRE_TIMEOUT_SECS=5
DATABASE_IDLE_TIMEOUT_SECS=300
DATABASE_MAX_LIFETIME_SECS=1800

# =============================================================================
# Redis
# =============================================================================
REDIS_URL=redis://localhost:6379
REDIS_POOL_SIZE=10

# =============================================================================
# JWT
# =============================================================================
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_USE_A_STRONG_256_BIT_KEY
JWT_ISSUER=english-notes-cloud
JWT_AUDIENCE=english-notes-frontend
JWT_ACCESS_TOKEN_EXPIRY_SECS=900
JWT_REFRESH_TOKEN_EXPIRY_SECS=604800

# =============================================================================
# Messaging
# =============================================================================
MESSAGING_BACKEND=nats
NATS_URL=nats://localhost:4222
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=english-notes-cloud
KAFKA_CLIENT_ID=english-notes-cloud

# =============================================================================
# Observability
# =============================================================================
OTEL_ENABLED=false
OTEL_SERVICE_NAME=english-notes-cloud
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# =============================================================================
# Outbox Worker
# =============================================================================
OUTBOX_POLL_INTERVAL_MS=500
OUTBOX_BATCH_SIZE=50
OUTBOX_MAX_RETRIES=5

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_REQUESTS_PER_SECOND=50
RATE_LIMIT_BURST=100
